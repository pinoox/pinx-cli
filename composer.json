{
  "name": "pinoox/pinx-cli",
  "version": "1.0.0",
  "description": "Developer CLI for single-app Pinoox projects — scaffold, dev, build, and release .pinx packages",
  "type": "library",
  "license": "MIT",
  "keywords": ["pinoox", "pinx", "cli", "hmvc"],
  "require": {
    "php": "^8.1",
    "symfony/console": "^6.4|^7.0",
    "symfony/process": "^6.4|^7.0"
  },
  "autoload": {
    "psr-4": {
      "Pinoox\\PinxCli\\": "src/"
    }
  },
  "bin": [
    "bin/pinx"
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
